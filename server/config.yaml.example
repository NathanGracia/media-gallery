# ── Media Gallery v3 — Configuration serveur ──────────────────────────────────
# Copier ce fichier en config.yaml et remplir les valeurs

media_dir: media
thumb_dir: thumbnails
db_path: db.sqlite

max_total_gb: 40
max_file_mb: 25
alert_threshold_pct: 80

# URL du webhook Discord pour les alertes de stockage (laisser vide pour désactiver)
discord_webhook_url: ""

# Clés API autorisées pour les feeders — et aussi pour Shardoss côté pull de
# stats (GET /api/shardoss/stats), ajouter une clé dédiée à la liste plutôt
# que de réutiliser celle du feeder.
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
api_keys:
  - "REMPLACE_MOI_AVEC_UNE_CLE_SECRETE"

host: 0.0.0.0
port: 8000

# URL publique du site (utilisée pour les previews Open Graph — Discord, iMessage…)
# Exemple : https://memoss.mondomaine.com
public_url: ""

# Secret partagé avec cooloss (compte unifié) — doit être IDENTIQUE à
# SHARED_SESSION_SECRET dans cooloss/.env, sinon les sessions ne sont pas
# reconnues. Ne réutilise pas une clé api_keys existante.
shared_session_secret: ""

# Shardoss (jeu idle connecté, repo séparé NathanGracia/shardoss). Laisser
# vide en dev pour désactiver silencieusement la notification de fin de
# partie (server/shardoss_client.py). shardoss_webhook_key doit être
# IDENTIQUE à memoss_webhook_key dans le config.yaml de Shardoss.
shardoss_base_url: ""
shardoss_webhook_key: ""
